PROXY_PASS=replace-with-a-long-random-secret
PROXY_IP_LOCATION=xxx.xxx.xxx
PROXY_IP_LOCATION=xxx.xxx.xxx

# ── Firecrawl: local, free, no cloud account ────────────────────────────────

# Bind the Firecrawl API to this port on the host.
FIRECRAWL_PORT=3002

# Turn off Firecrawl's Supabase/database authentication.
USE_DB_AUTHENTICATION=false

# Used by Firecrawl's local Bull queue dashboard.
# Make this a real random string; never commit it.
BULL_AUTH_KEY=replace-with-a-long-random-secret

# Keep local browser/queue workload intentionally small.
NUM_WORKERS_PER_QUEUE=2
CRAWL_CONCURRENT_REQUESTS=2
MAX_CONCURRENT_JOBS=2
BROWSER_POOL_SIZE=1

# Firecrawl uses these Docker-internal hostnames.
REDIS_URL=redis://redis:6379
REDIS_RATE_LIMIT_URL=redis://redis:6379
PLAYWRIGHT_MICROSERVICE_URL=http://playwright-service:3000/scrape

# Prowl's app-level service URLs.
SEARXNG_URL=http://127.0.0.1:8888
FIRECRAWL_URL=http://127.0.0.1:3002

# ── Prowl model — single OpenAI-compatible endpoint (Qwen) ──────────────────
# One model serves both PLAN (query planning) and SYNTHESIZE (output) in v0.1.
# Point PROWL_MODEL_BASE_URL at any OpenAI-compatible gateway
# (Venice / OpenRouter / a local proxy) and PROWL_MODEL at the model id.
PROWL_MODEL_API_KEY=
PROWL_MODEL_BASE_URL=
PROWL_MODEL=qwen3.6-plus
